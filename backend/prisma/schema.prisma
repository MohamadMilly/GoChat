// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
  previewFeatures = ["typedSql"]
}
 
datasource db {
  provider = "postgresql"
   url = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}
  
 
 model User {
  id Int @id @default(autoincrement())
  firstname String
  lastname String
  username String @unique
  password String
  profile Profile?
  conversations ConversationParticipant[]
  adminConversations ConversationAdmin[] 
  messages Message[]
  deleted Boolean @default(false)
  createdAt DateTime @default(now())
  preferences Preferences? @relation("preferences to user")
  banningUsers Ban[]  @relation("banningRelation")
  bannedUsers Ban[] @relation("bannedRelation")
  accountColor String?
  readMessages MessageOnReader[]
  @@map("users")
  }
  
model Profile {
id Int @id @default(autoincrement())
user User @relation(fields: [userId],references: [id])
userId Int @unique
bio String?
phoneNumber String? @unique
birthday DateTime?
email String? @unique
avatar String?
avatarBackground String?
lastSeen DateTime?
}


model Conversation {
id Int @id @default(autoincrement())
title String?
avatar String?
description String?
type ConversationType @default(DIRECT)
participants ConversationParticipant[] 
messages Message[]
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
admins ConversationAdmin[]
permissions Permissions?
}

model Ban {
  id Int @id @default(autoincrement())
  banBy User @relation("bannedRelation",fields: [banningUserId],references: [id])
  banningUserId Int
  banned User @relation("banningRelation",fields: [bannedUserId],references: [id])
  bannedUserId Int
   
  @@unique([bannedUserId,banningUserId])
  
}

 

model ConversationAdmin {
  id Int @id @default(autoincrement())
  conversation Conversation @relation(fields: [conversationId],references: [id])
  conversationId Int
  isOwner Boolean @default(false)
  user User @relation(fields: [userId],references: [id])
  userId Int
  assignedAt DateTime @default(now())
  assignedBy ConversationAdmin? @relation("admins assigned",fields: [assigningUserId],references: [id])
  assigningUserId Int?
  assignedAdmins ConversationAdmin[] @relation("admins assigned")
  
  @@unique([conversationId,userId])
}

model ConversationParticipant {
id Int @id @default(autoincrement())
conversation Conversation @relation(fields: [conversationId],references: [id])
conversationId Int
user User @relation(fields: [userId],references: [id])
userId Int
joinedAt DateTime @default(now())
reactions Reaction[]
@@unique([conversationId,userId])
}


model Preferences {
id Int @id @default(autoincrement())
user User @relation("preferences to user",fields: [userId],references: [id])
userId Int @unique 
isEmailHidden Boolean @default(true)
isPhoneNumberHidden Boolean @default(true)
isAvatarHidden Boolean @default(false)
isBioHidden Boolean @default(false)
isAvatarBackgroundHidden Boolean @default(false)
isBirthdayHidden Boolean @default(false)
}


model MessageOnReader {
seenAt DateTime @default(now())
message Message @relation(fields: [messageId],references: [id])
messageId Int
reader User @relation(fields: [readerId],references: [id])
readerId Int

@@id([messageId,readerId])
}

model Reaction {
id Int @id @default(autoincrement())
message Message @relation(fields: [messageId],references: [id])
messageId Int
reactor ConversationParticipant @relation(fields: [reactorId,conversationId],references: [userId,conversationId])
reactorId Int
conversationId Int
reactedAt DateTime @default(now())
type ReactionType @default(LIKE)
}

enum ReactionType {
  LIKE
  LOVE
  LAUGH
  ANGER
  CRY
  FIRE
  HEARTS_FACE
  SAD
  COOL
  NAIL_POLISH
}



model Message {
  id Int @id @default(autoincrement())
  sender User @relation(fields: [senderId],references: [id])
  senderId Int
  conversation Conversation @relation(fields: [conversationId],references: [id])
  conversationId Int
  content String?
  createdAt DateTime @default(now())
  editedAt DateTime? @updatedAt
  edit Boolean @default(false)
  type MessageType @default(TEXT)
  fileURL String?
  mimeType String?
  clientOffset String?
  readers MessageOnReader[]
  repliedMessage Message? @relation(fields: [repliedMessageId] ,references: [id],"reply to message")
  repliedMessageId Int?
  replies Message[] @relation("reply to message")
  reactions Reaction[]
}

model Permissions {
id Int @id @default(autoincrement())
conversation Conversation @relation(fields: [conversationId],references: [id])
conversationId Int @unique
sendingMessages Boolean @default(true)
sendingMedia Boolean @default(true)
onlineMembers Boolean @default(true)
hideUsersForVisitors Boolean @default(false)
messageReaders Boolean @default(true)
viewMembers Boolean @default(true)
}

enum VerificationType {
  EMAIL
  PHONE
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  IMAGE 
  FILE
}
